#ElementalDragons

import random
import time # to place pauses for better readability
from inputimeout import inputimeout, TimeoutOccurred
# import threading

# Timer display function
def display_timer(seconds):
    for i in range(seconds, 0, -1):
        print(f"\rTime remaining: {i} seconds", end="", flush=True)
        time.sleep(1)
    print("\rTime's up!                 ")  # Clear the timer line

dragonweakness = { # dictionary for dragon weaknesses
    'fire' : 'water',
    'water' : 'earth',
    'air' : 'water',
    'earth' : 'fire'
}


# Function to fight the dragon
def dragon_fight(dragon_type):
    print(f"\nYou encounter a {dragon_type} dragon!")
    time.sleep(1)  
    element = input("\nChoose an element to attack back with (fire, water, earth, air): ").lower()
    time.sleep(1)
    if element == dragonweakness[dragon_type]:
        print(f"\nSuccess! You used {element} and defeated the {dragon_type} dragon! ")
        time.sleep(2)
        elemental_fight() # Moves on with the story
    else:
        failed()
        
# Big dragon fight
def elemental_fight():
    # First attack
    print("\nYou continue on your adventure...")
    time.sleep(2)
    print("\nWait whats that?")
    time.sleep(1)
    print("\nYou hear a roar!!!!")
    time.sleep(1)
    print("\nA bigger dragon appeared! It throws a FIRE attack!")
    time.sleep(1)
    print("\nYou have no time to react what element do you use?")
    valid_elements = ["fire", "water", "earth", "air"] # the only options for user input
    while True: # loop to allow only the correct inputs
        timeout_seconds = 8 
        print(f"\nYou have {timeout_seconds} seconds!") # to tell user how much time they have to answer
        try:
            fight1 = inputimeout(prompt="Choose an element quick! (fire, water, earth, air): ", timeout=timeout_seconds).lower() # input with a timer, if user does not answer in time, it will go to except
        except TimeoutOccurred:
            print("\nRan out of time it got you!")
            failed()
            break
        if fight1 not in valid_elements:  # If input is not a choice, this section will repeat until a correct input is inserted
            print("Invalid choice!")
            continue 

        elif fight1 == "water": # the only answer that can defeat the dragon
            time.sleep(1)
            print(f"\nSuccess! You used {fight1}!")
            time.sleep(1)
            print("Try leave before it wakes up.. ")
            time.sleep(1)

            # Hide and Seek
            hiding_place = ["rocks", "giant mushroom", "vines"]
            dragon_choice = random.choice(hiding_place)

            fight2 = input("\nIt woke up! Where do you want to hide?? by the rocks, giant mushroom or vines? ").lower() # user input for hiding, no timer for this one
            time.sleep(2)
            print("The dragon wanders. . . \nlistening in. . .")
            time.sleep(2)
        
            if fight2 == dragon_choice: # if user picks the same hiding place as the dragon, they get caught
                print("\nYou got caught! He drags you out the cave. . .")
                time.sleep(1)
                failed()

            else: # if user picks a different hiding place, they move onto riddle
                print("\nYou hid well..")
                time.sleep(1)
                print("\nLeave while you can.")
                time.sleep(1)
                print("\nRAWRRRRRR! He caught you!")
                time.sleep(1)
                print("\nAnswer this riddle correctly and you'll live!")
                time.sleep(1)

                # Riddle 
                riddle = input("\nRiddle: I speak without a mouth and hear without ears. What am I? ").lower()
                if riddle == "echo":
                    time.sleep(1)
                    print(".")
                    time.sleep(1)
                    print(".")
                    time.sleep(1)
                    print(".")
                    time.sleep(1)
                    print("Correct! You escape safely with the crown! Take back my crown and meet me by the castle for your reward!")
                else:
                    print("Wrong answer!")
                    failed()
            break
        else:
            print(f"{fight1} is ineffective to fire types...") # if user picks the wrong element, they get a message and then the game ends
            failed()
            break

# Optional restart
def failed():
    print(f"Oh no! The dragon defeats you. Game over.")
    time.sleep(1)
    print("Would you like to try again?")
    restart = input("Type yes or no: ").lower()
    if restart == 'yes':
        print("Restarting . . .")
        time.sleep(1)
        adventure()        
    else:
        return

# Adventure beginning
def adventure():
    print("Adventure Time!")
    time.sleep(1)
    print("\nYou have been given a quest to get back my crown!")
    time.sleep(1)

    while True:  # First choice loop
        print("\nYou see two paths ahead: cloudy or sunny")
        choice1 = input("Which path will you take? ").lower()

        if choice1 == "cloudy":
            print("\nYou travel onwards...")
            time.sleep(2)
            print("You arrive in the forest")
            time.sleep(1)
            while True:  # Second choice loop
                print("\nOptions: continue, cave, back")
                choice2 = input("What do you do? ").lower()

                if choice2 == "cave":
                    print("You enter the cave...")
                    dragon_type = "fire"
                    dragon_fight(dragon_type)
                    return

                elif choice2 == "continue":
                    print("You continue deeper into the forest...")
                    dragon_type = "earth"
                    dragon_fight(dragon_type)
                    return

                elif choice2 == "back":
                    break  # goes back to first choice

                else: # If input is not a choice, this section will repeat until a correct input is inserted
                    print("Invalid choice.")

        elif choice1 == "sunny":
            print("\nYou feel a cool breeze...")
            time.sleep(2)
            print("You arrive at the river")
            time.sleep(1)
            while True: # second choice loop
                print("\nOptions: continue, mountains, back")
                choice2 = input("What do you do? ").lower()

                if choice2 == "mountains":
                    print("You climb the mountains...")
                    dragon_type = "air"
                    dragon_fight(dragon_type)
                    return

                elif choice2 == "continue":
                    print("You follow the river...")
                    dragon_type = "water"
                    dragon_fight(dragon_type)
                    return

                elif choice2 == "back":
                    break

                else:  # If input is not a choice, this section will repeat until a correct input is inserted
                    print("Invalid choice.")

        else:
            print("Invalid choice.")


adventure() # A call to start the main function

        
